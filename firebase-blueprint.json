{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a teacher's profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User ID (matches Firebase Auth UID)" },
        "name": { "type": "string", "description": "Teacher's full name" },
        "bio": { "type": "string", "description": "Teacher's biography" },
        "username": { "type": "string", "description": "Unique username for the public profile URL" },
        "image": { "type": "string", "description": "Profile image URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "plan": { "type": "string", "enum": ["free", "pro"], "description": "Subscription plan" }
      },
      "required": ["id", "name", "username", "createdAt", "plan"]
    },
    "Video": {
      "title": "Video",
      "description": "Represents a YouTube video uploaded by a teacher.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document ID" },
        "userId": { "type": "string", "description": "ID of the teacher who uploaded the video" },
        "title": { "type": "string", "description": "Video title" },
        "description": { "type": "string", "description": "Video description" },
        "videoId": { "type": "string", "description": "YouTube Video ID" },
        "youtubeUrl": { "type": "string", "description": "Full YouTube URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "title", "videoId", "youtubeUrl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores teacher profiles."
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Stores videos uploaded by teachers."
    }
  }
}
